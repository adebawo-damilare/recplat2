    "release:prod:db:apply:users": "dotenv -o -e .env.release -- npm run db:apply:users",
    "release:prod:db:apply:roles": "dotenv -o -e .env.release -- npm run db:apply:roles",
    "release:prod:db:apply:application-status": "dotenv -o -e .env.release -- npm run db:apply:application-status",
    "release:prod:db:apply:candidate-name-split": "dotenv -o -e .env.release -- npm run db:apply:candidate-name-split",
    "release:prod:db:check:migrations": "dotenv -o -e .env.release -- npm run db:check:migrations",
    "release:prod:db:repair-migration-checksums": "dotenv -o -e .env.release -- npm run db:repair-migration-checksums",
    "release:preview:db:check:migrations": "dotenv -o -e .env.local -- npm run db:check:migrations",
    "release:preview:db:repair-migration-checksums": "dotenv -o -e .env.local -- npm run db:repair-migration-checksums",
    "release:prod:smoke": "dotenv -e .env.release -- npm run smoke:api",
    "release:prod:smoke:screening-review": "dotenv -o -e .env.release -- node scripts/smoke-screening-review-prod.mjs",
    "release:prod:smoke:screening-review:ui": "dotenv -o -e .env.release -- node scripts/smoke-screening-review-ui-prod.mjs",
    "test:e2e": "playwright test",
    "test:e2e:auth": "node scripts/e2e-auth.mjs",
    "test:e2e:ui": "playwright test --ui",
    "test:load": "node scripts/load-test.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/typography": "^0.5.19",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "jose": "^6.2.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "next": "^15.5.5",
    "postgres": "^3.4.9",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4.1.14",
    "@tailwindcss/vite": "^4.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autocannon": "^8.0.0",
    "autoprefixer": "^10.4.21",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
