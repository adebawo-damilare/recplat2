{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "dev:vite": "vite --port=3000 --host=0.0.0.0",
    "build:vite": "vite build",
    "preview:vite": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "db:apply": "node scripts/db-apply.mjs",
    "db:apply:categories": "node scripts/db-apply.mjs database/migrations/0002_categories.sql",
    "db:apply:users": "node scripts/db-apply.mjs database/migrations/0003_users_auth.sql",
    "db:apply:roles": "node scripts/db-apply.mjs database/migrations/0004_user_roles.sql",
    "db:apply:application-status": "node scripts/db-apply.mjs database/migrations/0005_application_status.sql",
    "db:apply:candidate-name-split": "node scripts/db-apply.mjs database/migrations/0006_candidate_name_split.sql",
