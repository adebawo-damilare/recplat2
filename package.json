    "db:check:migrations": "node scripts/db-check-migrations.mjs",
    "db:repair-migration-checksums": "node scripts/db-repair-migration-checksums.mjs",
    "db:check:parity": "node scripts/db-check-parity.mjs",
    "db:seed:samples": "tsx scripts/seed-neon-sample.ts",
    "smoke:api": "node scripts/smoke-api.mjs",
