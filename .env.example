# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Public site URL for sitemap/canonical URLs in production (optional in dev).
# NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"

# Postgres (optional). When set, server uses SQL for vacancies/companies/applications.
# DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# Jobs Slice v1 — production: require Postgres for vacancy/listing + applications (no Firestore fallback on server).
# TALENTBRIDGE_JOBS_POSTGRES_ONLY=1

# Jobs Slice v1 — production build: client skips Firestore fallbacks for job/application APIs (set at build time).
# NEXT_PUBLIC_TALENTBRIDGE_JOBS_POSTGRES_ONLY=1

# Firebase Admin (required for POST/PATCH /api/jobs, /api/applications when using Postgres path).
# Option A — path to downloaded key (recommended locally; use: npm run env:firebase -- "C:/path/key.json"):
# FIREBASE_SERVICE_ACCOUNT_PATH=C:/Users/YOU/Downloads/project-firebase-adminsdk-xxxxx.json
# Option B — inline JSON (often used on Vercel):
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# Option C — standard Google env (path to JSON file):
# GOOGLE_APPLICATION_CREDENTIALS=C:/path/key.json

# AI (optional; defaults to mock if no keys)
# TALENTBRIDGE_AI_PROVIDER=mock
# TALENTBRIDGE_AI_MODEL=gpt-5.4-mini
# OPENAI_API_KEY=""

# Postgres connection pool hint (optional, server reads if wired)
# POSTGRES_POOL_MAX=5

# Seed script: owner uid for sample rows (optional; default is a placeholder string)
# SEED_OWNER_FIREBASE_UID=

# Upstash Redis (optional). When set, /api/jobs uses distributed rate limiting.
# Create a database at https://upstash.com and paste REST credentials.
# UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN=""
