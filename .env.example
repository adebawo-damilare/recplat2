# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Public site URL for sitemap/canonical URLs in production (optional in dev).
# NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"

# Postgres (optional). When set, server uses SQL for vacancies/companies/applications.
# DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# Jobs Slice v1 — production: require Postgres for vacancy/listing + applications (no Firestore fallback on server).
# TALENTBRIDGE_JOBS_POSTGRES_ONLY=1

# Jobs Slice v1 — production build: strict client handling for job/application API failures (set at build time).
# NEXT_PUBLIC_TALENTBRIDGE_JOBS_POSTGRES_ONLY=1

# Postgres auth: JWT session signing (min 32 chars). Required for /api/auth/register, /api/auth/login, and protected APIs.
# Also required for `npm run test:e2e:auth` (Playwright registers a throwaway user against your dev server).
# TALENTBRIDGE_AUTH_SECRET=

# CI / local only: allow session cookies without Secure when NODE_ENV=production but the app is served over plain HTTP
# (e.g. Playwright against `next start` on http://127.0.0.1). Never set on real HTTPS production.
# TALENTBRIDGE_SESSION_ALLOW_HTTP=1

# AI (optional; defaults to mock if no keys)
# TALENTBRIDGE_AI_PROVIDER=mock
# TALENTBRIDGE_AI_MODEL=gpt-5.4-mini
# OPENAI_API_KEY=""

# Postgres connection pool hint (optional, server reads if wired)
# POSTGRES_POOL_MAX=5

# Seed script: owner Postgres user id (UUID string) for sample vacancy rows (optional)
# SEED_OWNER_USER_ID=

# Upstash Redis (optional). When set, /api/jobs uses distributed rate limiting.
# Create a database at https://upstash.com and paste REST credentials.
# UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN=""

# Production checklist (scripts/run-prod-checklist.mjs): when PROD_CHECKLIST_ORIGIN matches
# SMOKE_BASE_URL, set ALLOW_PROD_CHECKLIST_MUTATIONS=1 or the script exits (see docs/PROD_CHECKLIST.md).
PROD_CHECKLIST_ORIGIN="https://your-app.vercel.app"
ALLOW_PROD_CHECKLIST_MUTATIONS=
