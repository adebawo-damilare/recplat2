# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Public site URL for sitemap/canonical URLs in production (optional in dev).
# NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"

# Postgres (optional). When set, server uses SQL for vacancies/companies/applications.
# DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# Firebase Admin (required for POST/PATCH /api/jobs, /api/applications when using Postgres path).
# Paste the full JSON service account as a single line, or use GOOGLE_APPLICATION_CREDENTIALS in GCP.
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

# AI (optional; defaults to mock if no keys)
# TALENTBRIDGE_AI_PROVIDER=mock
# TALENTBRIDGE_AI_MODEL=gpt-5.4-mini
# OPENAI_API_KEY=""

# Postgres connection pool hint (optional, server reads if wired)
# POSTGRES_POOL_MAX=5

# Upstash Redis (optional). When set, /api/jobs uses distributed rate limiting.
# Create a database at https://upstash.com and paste REST credentials.
# UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN=""
